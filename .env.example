# MCP Server 运行模式: stdio 或 sse
MCP_TYPE=sse

# SSE 模式监听端口
PORT=8000

# MeterSphere API 版本: v2 或 v3 (默认 v3)
# v2 - MeterSphere 2.x 版本接口
# v3 - MeterSphere 3.x 版本接口
MS_VERSION=v3

# MeterSphere 访问密钥 (STDIO 模式必填)
accessKey=

# MeterSphere 签名密钥/SecretKey (STDIO 模式必填)
signature=

# MeterSphere 服务地址 (STDIO 模式必填)
meterSphereUrl=
